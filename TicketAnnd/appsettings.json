{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27018",
    "Database": "ticketannd"
  },
   "Serilog": {
      "MinimumLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore.OutputCaching": "Debug",
        "Override": {
          "Microsoft": "Information",
          "System": "Warning"
        }
      },
  
      "WriteTo": [
        {
          "Name": "Console"
        },
        {
          "Name": "File",
          "Args": {
            "path": "Logs/log-.txt",
            "rollingInterval": "Day",
            "retainedFileCountLimit": 7
          }
        }
  
      ]
    },
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.OutputCaching": "Debug"
      }
  },
  "Jwt": {
    "Key": "dev-symmetric-key-at-least-32-characters-long-for-hs256",
    "Issuer": "TicketAnnd",
    "Audience": "TicketAnnd",
    "ExpiryMinutes": 60
  },
  "Mailtrap": {
    "Host": "smtp.mailtrap.io",
    "Port": 2525,
    "UserName": "",
    "Password": "",
    "FromEmail": ""
  },
  "SeedAdmin": {
    "Email": "",
    "Password": ""
  }
}
